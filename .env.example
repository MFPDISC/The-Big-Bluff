# Server Configuration
NODE_ENV=production
PORT=5002
CLIENT_URL=https://yourdomain.com

# Database (Use strong credentials in production)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Redis Cache (Use password in production)
REDIS_URL=redis://:password@localhost:6379

# API Keys - NEVER COMMIT REAL VALUES TO GIT
# Get free keys from these sources:

# Alpha Vantage - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# FRED (Federal Reserve) - https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Financial Modeling Prep (Optional - $15/mo) - https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_key_here

# CoinGecko (Free tier available) - https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_key_here

# Glassnode (Optional - $39/mo) - https://glassnode.com
GLASSNODE_API_KEY=your_glassnode_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Secret (Generate random 32+ character string)
SESSION_SECRET=generate_random_32_character_string_here

# Data Refresh Settings
MARKET_HOURS_REFRESH=900000
AFTER_HOURS_REFRESH=3600000
CACHE_TTL=60
