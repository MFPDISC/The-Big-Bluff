# Glassnode (Optional - $39/mo) - https://glassnode.com
GLASSNODE_API_KEY=your_glassnode_key_here

# Data Refresh Settings
MARKET_HOURS_REFRESH=900000
AFTER_HOURS_REFRESH=3600000
CACHE_TTL=60
